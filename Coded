<!DOCTYPE html>
<html>
<head>
  <title>Code Quest</title>
  <style>
    #editor {
      width: 100%;
      height: 300px;
      border: 1px solid #ccc;
    }
  </style>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.39.0/min/vs/loader.min.js"></script>
</head>
<body>

  <h1>Episode 1: The Gate</h1>
  <p>เขียน C++ ที่รับ 2 ตัวเลข แล้ว cout ผลรวมออกมา</p>
  
  <div id="editor"></div>

  <button id="submit-btn">ตอบ</button>

  <h3>ผลลัพธ์:</h3>
  <div id="output"></div>

  <script>
    // 1. บอกให้ระบบรู้ว่าจะโหลด Monaco Editor จากที่ไหน
    require.config({ paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.39.0/min/vs' } });

    // 2. สั่งให้เริ่มต้นสร้าง Editor ขึ้นมาในกล่อง id="editor"
    require(['vs/editor/editor.main'], function() {
        monaco.editor.create(document.getElementById('editor'), {
            value: '// เขียนโค้ด C++ ของคุณที่นี่\n#include <iostream>\nusing namespace std;\n\nint main() {\n    \n    return 0;\n}',
            language: 'cpp',
            theme: 'vs-dark'
        });
    });
  </script>

</body>
</html>
