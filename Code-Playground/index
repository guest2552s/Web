<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.44.0/min/vs/loader.js"></script>
        <title>
            grader
        </title>
        <style>
            body {
                font-family: sans-serif;
                padding: 20px;
            }
            #edit{
                width: 80%;
                height: 300px;
                border: 1px solid #35046d;
            }
            #stdin {
                width: 80%;
                height: 60px;
                margin-top: 10px;
                font-family: monospace;
            }
            #submit {
                margin-top: 10px;
                padding: 8px 20px;
                font-size: 16px;
                cursor: pointer;
            }
            #out {
                white-space: pre-wrap;
                background: #1e1e1e;
                color: #d4d4d4;
                padding: 10px;
                width: 80%;
                min-height: 50px;
                font-family: monospace;
                border-radius: 4px;
            }
            #status {
                font-weight: bold;
                margin-top: 5px;
            }
        </style>
    </head>
    <body>
        <h1>
            EP1
        </h1>
        <p>
            cout 2 ตัวเลขมา
        </p>
        <div id="edit"></div>

        <p>Input (stdin) - ใส่ 2 ตัวเลขที่จะป้อนให้โปรแกรม:</p>
        <textarea id="stdin" placeholder="เช่น: 3 5">3 5</textarea>

        <br>
        <button id="submit">ตอบ</button>
        <div id="status"></div>

        <h3>ผล:</h3>
        <div id="out"></div>

        <script>
            require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.44.0/min/vs' } });
            let editor;
            require(['vs/editor/editor.main'], function(){
                editor = monaco.editor.create(document.getElementById('edit'), {
                    value: '#include<bits/stdc++.h>\nusing namespace std;\nint main(){\n\n}',
                    language: 'cpp',
                    theme: 'vs-dark',
                });
            });

            function sleep(ms) {
                return new Promise(resolve => setTimeout(resolve, ms));
            }

            async function submitCode() {
                const code = editor.getValue();
                const stdin = document.getElementById('stdin').value;
                const outDiv = document.getElementById('out');
                const statusDiv = document.getElementById('status');
                const submitBtn = document.getElementById('submit');

                submitBtn.disabled = true;
                statusDiv.textContent = 'กำลังส่งโค้ด...';
                outDiv.textContent = '';

                try {
                    // Call OUR OWN backend, not Judge0 directly. No key here.
                    const createResp = await fetch('/api/submit', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ code, stdin })
                    });

                    const createData = await createResp.json();

                    if (!createResp.ok) {
                        throw new Error(JSON.stringify(createData.error || createData));
                    }

                    const token = createData.token;

                    statusDiv.textContent = 'กำลังคอมไพล์และรัน...';
                    let result;
                    for (let i = 0; i < 20; i++) {
                        await sleep(1000);
                        const pollResp = await fetch(`/api/result?token=${encodeURIComponent(token)}`);
                        const pollData = await pollResp.json();

                        if (!pollResp.ok) {
                            throw new Error(JSON.stringify(pollData.error || pollData));
                        }

                        result = pollData;
                        if (result.status.id > 2) break; // done
                    }

                    if (result.compile_output) {
                        statusDiv.textContent = 'Compile Error';
                        outDiv.textContent = result.compile_output;
                    } else if (result.stderr) {
                        statusDiv.textContent = 'Runtime Error (' + result.status.description + ')';
                        outDiv.textContent = result.stderr;
                    } else {
                        statusDiv.textContent = result.status.description + ' (เวลา: ' + result.time + 's, memory: ' + result.memory + ' KB)';
                        outDiv.textContent = result.stdout || '(ไม่มี output)';
                    }
                } catch (err) {
                    statusDiv.textContent = 'เกิดข้อผิดพลาด';
                    outDiv.textContent = err.message;
                } finally {
                    submitBtn.disabled = false;
                }
            }

            document.getElementById('submit').addEventListener('click', submitCode);
        </script>
    </body>
</html>
